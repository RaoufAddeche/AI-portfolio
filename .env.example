# Copier en .env et remplir. Le .env n'est JAMAIS commité (voir .gitignore).

# ===== PostgreSQL =====
POSTGRES_USER=portfolio_admin
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=portfolio

# ===== Backend (mêmes valeurs que la DB) =====
DB_HOST=db
DB_PORT=5432
DB_USER=portfolio_admin
DB_PASSWORD=change_me_to_a_strong_password
DB_NAME=portfolio

# ===== GitHub (synchro des repos vers le portfolio) =====
# Token : https://github.com/settings/tokens (scope: public_repo en lecture)
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_USERNAME=your_github_username

# ===== LLM (résumés de projets à la demande, via API — pas de modèle local) =====
OPENAI_API_KEY=sk-your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Garde-fous chatbot (anti-spam / budget). Optionnels (valeurs par défaut sinon).
# CHAT_RATE_PER_MINUTE=6
# CHAT_DAILY_LIMIT=300

# Protège POST /api/github/sync en prod. Si défini, l'appel exige l'en-tête
# X-Sync-Token. Génère une valeur forte : openssl rand -hex 24
# SYNC_TOKEN=

# Notification email du formulaire de contact (https://resend.com, offre gratuite).
# Sans clé : les messages restent en base, mais aucun email n'est envoyé.
# RESEND_API_KEY=re_xxx
# CONTACT_NOTIFY_TO=ton-email@example.com
# from doit être un domaine vérifié ; onboarding@resend.dev marche vers TON email Resend.
# CONTACT_FROM=Portfolio <onboarding@resend.dev>

# CV lu par le chatbot : URL interne du frontend qui sert ton PDF.
# Adapte au nom de TON fichier placé dans frontend/public/.
# CV_URL=http://frontend/cv.pdf

# Modération des avis : secret signant les liens d'approbation reçus par email.
# openssl rand -hex 24 ; PUBLIC_BASE_URL = URL publique de l'API (pour le lien cliquable).
# ADMIN_TOKEN=
# PUBLIC_BASE_URL=http://localhost:8000

# IP à exclure des analytics (les tiennes), séparées par des virgules. Récupère
# ton IP via la page /admin (bandeau « Ton IP actuelle ») ou « curl ifconfig.me ».
# ANALYTICS_EXCLUDE_IPS=

# ===== Déploiement (docker-compose.prod.yml + Caddy) =====
# Domaine public servi par Caddy (HTTPS auto). Ex: raoufaddeche.duckdns.org
# En prod, PUBLIC_BASE_URL est dérivé en https://$DOMAIN automatiquement.
# DOMAIN=raoufaddeche.duckdns.org

# ===== Frontend =====
VITE_API_URL=http://localhost:8000
