# Copier en .env et remplir. Le .env n'est JAMAIS commité (voir .gitignore).

# ===== PostgreSQL =====
POSTGRES_USER=portfolio_admin
POSTGRES_PASSWORD=change_me_to_a_strong_password
POSTGRES_DB=portfolio

# ===== Backend (mêmes valeurs que la DB) =====
DB_HOST=db
DB_PORT=5432
DB_USER=portfolio_admin
DB_PASSWORD=change_me_to_a_strong_password
DB_NAME=portfolio

# ===== GitHub (synchro des repos vers le portfolio) =====
# Token : https://github.com/settings/tokens (scope: public_repo en lecture)
GITHUB_TOKEN=ghp_your_github_token_here
GITHUB_USERNAME=your_github_username

# ===== LLM (résumés de projets à la demande, via API — pas de modèle local) =====
OPENAI_API_KEY=sk-your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Garde-fous chatbot (anti-spam / budget). Optionnels (valeurs par défaut sinon).
# CHAT_RATE_PER_MINUTE=6
# CHAT_DAILY_LIMIT=300

# Protège POST /api/github/sync en prod. Si défini, l'appel exige l'en-tête
# X-Sync-Token. Génère une valeur forte : openssl rand -hex 24
# SYNC_TOKEN=

# ===== Frontend =====
VITE_API_URL=http://localhost:8000
